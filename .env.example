TELEGRAM_BOT_TOKEN=123456:your-telegram-bot-token
ANTHROPIC_API_KEY=sk-ant-your-key
TIMEZONE=Europe/Kyiv
# Comma-separated Telegram user IDs allowed to use the bot (owner only)
ALLOWED_USER_IDS=123456789
# Directory for all persistent files (DB, scheduler jobstore, logs, exports).
# On Railway point this at your mounted volume, e.g. /app/data
DATA_DIR=./data
# Daily time (HH:MM, local TIMEZONE) to send birthday reminders
BIRTHDAY_ALERT_TIME=15:00
